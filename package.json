{
  "name": "lightphone-input",
  "version": "0.1.3",
  "description": "Tree-shakeable React phone number input component with validation, masking, and country detection for 200+ countries.",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "test": "jest",
    "test:coverage": "jest --coverage",
    "build": "tsup",
    "prepare": "npm run build",
    "playground:install": "node ./scripts/playground-install.mjs",
    "playground:dev": "npm run playground:install && npm --prefix playground run dev",
    "playground:build": "npm run playground:install && npm --prefix playground run build",
    "playground:preview": "npm --prefix playground run preview"
  },
  "keywords": [
    "react",
    "phone",
    "input",
    "international",
    "phone-number"
  ],
  "author": "",
  "license": "MIT",
  "peerDependencies": {
    "react": ">=18",
    "react-dom": ">=18"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/jest": "^30.0.0",
    "@types/react": "^18.0.0",
    "@types/react-dom": "^18.3.7",
    "country-data": "^0.0.31",
    "jest": "^30.3.0",
    "jest-environment-jsdom": "^30.3.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "ts-jest": "^29.4.6",
    "tsup": "^7.0.0",
    "typescript": "^5.0.0"
  }
}
